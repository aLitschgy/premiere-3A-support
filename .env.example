# Configuration SMTP
# Hôte du serveur SMTP
SMTP_HOST=smtp.example.com

# Port SMTP (25, 465, 587)
SMTP_PORT=587

# Email d'envoi
SMTP_FROM_EMAIL=support@example.com

# Nom d'affichage pour l'envoi
SMTP_FROM_NAME=Support Technique

# Email destinataire (où les tickets seront envoyés)
SMTP_TO_EMAIL=admin@example.com
